{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resumeos.dev/schemas/1.0.0/opensource.schema.json",
  "title": "Open-source Contribution",
  "description": "An open-source contribution entity. One Markdown note per upstream project under vault/career/opensource/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_type",
    "project",
    "repo_url",
    "role",
    "sources"
  ],
  "properties": {
    "entity_type": {
      "type": "string",
      "const": "opensource",
      "description": "Discriminator; must always be 'opensource'."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Stable slug id, e.g. 'obsidian-dataview'."
    },
    "project": {
      "type": "string",
      "minLength": 2,
      "description": "Upstream project name, e.g. 'obsidian-dataview'."
    },
    "repo_url": {
      "type": "string",
      "format": "uri",
      "description": "Public repository URL."
    },
    "role": {
      "type": "string",
      "enum": [
        "maintainer",
        "contributor",
        "reviewer",
        "triage"
      ],
      "description": "Your role in this project."
    },
    "contributions": {
      "type": "array",
      "description": "List of discrete contributions.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "ref",
          "description"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "commit",
              "pr",
              "issue",
              "docs",
              "release"
            ],
            "description": "Type of contribution."
          },
          "ref": {
            "type": "string",
            "description": "Reference, e.g. PR number, commit SHA, issue number."
          },
          "description": {
            "type": "string",
            "description": "Short description of the contribution."
          }
        }
      },
      "default": []
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Programming languages involved."
    },
    "stars": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "description": "Repository star count, only if confirmed."
    },
    "merged_prs": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "description": "Number of merged PRs, only if confirmed."
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start"
      ],
      "properties": {
        "start": {
          "type": "string",
          "format": "date"
        },
        "end": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "ongoing": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "description": "Short description of the project and your involvement."
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Related note ids/titles (graph edges)."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Obsidian tags."
    },
    "confidence": {
      "type": "string",
      "enum": [
        "confirmed",
        "inferred",
        "missing"
      ],
      "default": "confirmed",
      "description": "Fact-confidence level (ADR-0007)."
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "description": "Provenance. REQUIRED.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "$resumeos": {
      "type": "object",
      "description": "ResumeOS extension namespace.",
      "additionalProperties": true,
      "properties": {
        "schema_version": {
          "type": "string",
          "default": "1.0.0"
        },
        "library_hints": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "history": {
      "type": "array",
      "default": [],
      "description": "Version history snapshots (ADR-0015). Appended on each entity update by career_builder/career_update. Top-level frontmatter is always the present state; history archives previous values only.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version",
          "captured_at",
          "changed_fields",
          "previous_values",
          "reason"
        ],
        "properties": {
          "version": {
            "type": "integer",
            "minimum": 1,
            "description": "Monotonic per-entity version, starts at 1 on creation."
          },
          "captured_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 datetime when this snapshot was captured."
          },
          "changed_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Frontmatter field names that changed in this version."
          },
          "previous_values": {
            "type": "object",
            "additionalProperties": true,
            "description": "Map of changed field -> its previous value. Only confirmed previous values (ADR-0007), never inferred."
          },
          "reason": {
            "type": "string",
            "enum": [
              "import",
              "user_edit",
              "skill_update",
              "merge"
            ],
            "description": "What caused this version bump."
          }
        }
      }
    },
    "relations": {
      "type": "array",
      "default": [],
      "description": "Typed directed relations to other entities (ADR-0016). Coexists with the untyped `related[]` field; `relations` is preferred where the relation type carries meaning. Each target MUST be a [[wikilink]] so Obsidian Graph View renders the edge.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "target"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "evidence",
              "reference",
              "derived_from",
              "part_of",
              "award_for",
              "author_of",
              "contributes_to"
            ],
            "description": "Relation type. Open to community additions via ADR-0004 namespacing."
          },
          "target": {
            "type": "string",
            "pattern": "^\\[\\[[^\\]]+\\]\\]$",
            "description": "Wikilink to the target entity, e.g. [[px4-uav]] or [[px4-uav|alias]]."
          },
          "note": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional free-text note on this relation."
          }
        }
      }
    }
  }
}
