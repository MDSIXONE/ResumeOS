{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resumeos.dev/schemas/1.0.0/internship.schema.json",
  "title": "Internship",
  "description": "An internship entity. One Markdown note per internship under vault/career/internships/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_type",
    "title",
    "company",
    "role",
    "timeline",
    "sources"
  ],
  "properties": {
    "entity_type": {
      "type": "string",
      "const": "internship",
      "description": "Discriminator; must always be 'internship'."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Stable slug id, e.g. 'byd-autonomy-2024'."
    },
    "title": {
      "type": "string",
      "minLength": 2,
      "description": "Internship title or position name."
    },
    "company": {
      "type": "string",
      "description": "Company name."
    },
    "team": {
      "type": [
        "string",
        "null"
      ],
      "description": "Team or department within the company."
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start"
      ],
      "properties": {
        "start": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 start date."
        },
        "end": {
          "type": [
            "string",
            "null"
          ],
          "format": "date",
          "description": "End date, or null if ongoing."
        },
        "ongoing": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "role": {
      "type": "string",
      "description": "Your role, e.g. 'Computer Vision Intern'."
    },
    "mentor": {
      "type": [
        "string",
        "null"
      ],
      "description": "Name of your mentor or supervisor, if known."
    },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "description": "Technical stack, split by layer.",
      "properties": {
        "hardware": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "software": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "protocol": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "algorithm": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "dataset": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "contribution": {
      "type": [
        "string",
        "null"
      ],
      "description": "One-line summary of what you contributed."
    },
    "metrics": {
      "type": "array",
      "description": "Quantified outcomes from the internship.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric",
          "value"
        ],
        "properties": {
          "metric": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "context": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "default": []
    },
    "outcome": {
      "type": [
        "string",
        "null"
      ],
      "description": "Summary of the outcome, e.g. 'deployed to 3 production lines'."
    },
    "offer": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Whether the internship led to a return offer."
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Related note ids/titles (graph edges)."
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "description": "Links to proof.",
      "properties": {
        "url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "image": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "default": [],
          "description": "Evidence image URIs/paths (0 or more)."
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Obsidian tags."
    },
    "confidence": {
      "type": "string",
      "enum": [
        "confirmed",
        "inferred",
        "missing"
      ],
      "default": "confirmed",
      "description": "Fact-confidence level (ADR-0007)."
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "description": "Provenance. REQUIRED.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "$resumeos": {
      "type": "object",
      "description": "ResumeOS extension namespace.",
      "additionalProperties": true,
      "properties": {
        "schema_version": {
          "type": "string",
          "default": "1.0.0"
        },
        "library_hints": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "history": {
      "type": "array",
      "default": [],
      "description": "Version history snapshots (ADR-0015). Appended on each entity update by career_builder/career_update. Top-level frontmatter is always the present state; history archives previous values only.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version",
          "captured_at",
          "changed_fields",
          "previous_values",
          "reason"
        ],
        "properties": {
          "version": {
            "type": "integer",
            "minimum": 1,
            "description": "Monotonic per-entity version, starts at 1 on creation."
          },
          "captured_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 datetime when this snapshot was captured."
          },
          "changed_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Frontmatter field names that changed in this version."
          },
          "previous_values": {
            "type": "object",
            "additionalProperties": true,
            "description": "Map of changed field -> its previous value. Only confirmed previous values (ADR-0007), never inferred."
          },
          "reason": {
            "type": "string",
            "enum": [
              "import",
              "user_edit",
              "skill_update",
              "merge"
            ],
            "description": "What caused this version bump."
          }
        }
      }
    },
    "relations": {
      "type": "array",
      "default": [],
      "description": "Typed directed relations to other entities (ADR-0016). Coexists with the untyped `related[]` field; `relations` is preferred where the relation type carries meaning. Each target MUST be a [[wikilink]] so Obsidian Graph View renders the edge.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "target"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "evidence",
              "reference",
              "derived_from",
              "part_of",
              "award_for",
              "author_of",
              "contributes_to"
            ],
            "description": "Relation type. Open to community additions via ADR-0004 namespacing."
          },
          "target": {
            "type": "string",
            "pattern": "^\\[\\[[^\\]]+\\]\\]$",
            "description": "Wikilink to the target entity, e.g. [[px4-uav]] or [[px4-uav|alias]]."
          },
          "note": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional free-text note on this relation."
          }
        }
      }
    }
  }
}
