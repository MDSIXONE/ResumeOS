{
  "$schema": "../../schemas/plugin-manifest.schema.json",
  "name": "resume_review",
  "version": "0.1.0",
  "description": "Review any resume (vault-derived or external) from ATS, recruiter, hiring manager, and tech lead perspectives with prioritized improvement suggestions.",
  "type": "skill",
  "license": "MIT",
  "depends_on": ["schema@1.0.0"],
  "hooks": [],
  "mcp_tools": [],
  "permissions": {
    "read":  ["vault/career/**", "schemas/**", "prompts/**", "config/**", "output/**"],
    "write": ["output/**"],
    "deny":  ["vault/career/** as write target", "vault/jobs/** as write target", "vault/.obsidian/**"]
  }
}
