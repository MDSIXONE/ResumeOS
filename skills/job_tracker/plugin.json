{
  "$schema": "../../schemas/plugin-manifest.schema.json",
  "name": "job_tracker",
  "version": "0.1.0",
  "description": "Track job applications, interviews, offers, and rejections in vault/jobs; maintain timelines and generate dashboards.",
  "type": "skill",
  "license": "MIT",
  "depends_on": ["schema@1.0.0"],
  "hooks": [],
  "mcp_tools": ["calendar:create", "email:read"],
  "permissions": {
    "read":  ["vault/jobs/**", "schemas/**", "prompts/**", "config/**"],
    "write": ["vault/jobs/**", "output/**"],
    "deny":  ["vault/career/**", "vault/.obsidian/**"]
  }
}
